<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.TimeSliceView"
             x:DataType="vm:TimeSliceViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0F000000"/>
        </Style>
        <Style Selector="Button.drill">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,7"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.drill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F1F5F9"/>
        </Style>
        <!-- A breadcrumb segment: link-style, accent colour, clickable -->
        <Style Selector="Button.crumb">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#005FB8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.crumb:pointerover /template/ ContentPresenter">
            <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
        </Style>
        <!-- One data cell: fixed width so header and rows line up; numbers right-aligned -->
        <Style Selector="TextBlock.cell">
            <Setter Property="Width" Value="100"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="18">

            <!-- Header: title + breadcrumb (left); 戻る + 集計期間 (right) -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="時間別 ・ 期間" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <ItemsControl ItemsSource="{Binding Breadcrumbs}" x:CompileBindings="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="crumb" Content="{Binding Display}"
                                        Command="{Binding $parent[ItemsControl].DataContext.NavigateCrumbCommand}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Button Content="← 戻る" VerticalAlignment="Center"
                            Command="{Binding DrillUpCommand}" IsVisible="{Binding CanDrillUp}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="集計期間" VerticalAlignment="Center" Foreground="#475569" FontSize="13"/>
                        <ComboBox ItemsSource="{Binding Periods}" SelectedItem="{Binding SelectedPeriod}"
                                  MinWidth="100" x:CompileBindings="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding ScopeSummary}" FontSize="13" Foreground="#64748B"
                               IsVisible="{Binding HasData}"/>
                    <TextBlock Text="{Binding EmptyMessage}" FontSize="13" Foreground="#94A3B8"
                               TextWrapping="Wrap" IsVisible="{Binding !HasData}"/>
                    <TextBlock Text="{Binding ChildLevelTitle}" FontSize="13" FontWeight="SemiBold"
                               Foreground="#334155" IsVisible="{Binding HasData}"/>

                    <!-- 期間 × 全データ項目 table; rows drill one level deeper -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding ShowChildren}">
                        <StackPanel Spacing="0">
                            <!-- column header -->
                            <StackPanel Orientation="Horizontal" Margin="6,0,6,4">
                                <TextBlock Text="期間" Width="170" FontSize="12" Foreground="#94A3B8"/>
                                <ItemsControl ItemsSource="{Binding Columns}" x:CompileBindings="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="100">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#475569" TextAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding AggregationLabel}" FontSize="10"
                                                           Foreground="#94A3B8" TextAlignment="Right"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <!-- data rows -->
                            <ItemsControl ItemsSource="{Binding Rows}" x:CompileBindings="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="drill"
                                                Command="{Binding $parent[ItemsControl].DataContext.DrillIntoCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" Width="170" FontSize="13"
                                                           Foreground="#334155" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Classes="cell" Text="{Binding}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Terminal: the individual responses for the selected day (記入日 + 抜粋, no PII) -->
                    <StackPanel IsVisible="{Binding ShowResponses}" Spacing="0">
                        <Grid ColumnDefinitions="140,*" Margin="6,0,0,6">
                            <TextBlock Grid.Column="0" Text="記入日" FontSize="12" Foreground="#94A3B8"/>
                            <TextBlock Grid.Column="1" Text="抜粋（フリーテキスト）" FontSize="12" Foreground="#94A3B8"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Responses}" x:CompileBindings="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="140,*" Margin="6,5">
                                        <TextBlock Grid.Column="0" Text="{Binding EntryDate}" FontSize="13"
                                                   Foreground="#334155" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Excerpt}" FontSize="13"
                                                   Foreground="#334155" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
