<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0F000000"/>
        </Style>
        <Style Selector="Button.bar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="18">

            <!-- Header: title + month picker -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="ダッシュボード" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding Breadcrumb}" FontSize="13" Foreground="#64748B"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="対象月" VerticalAlignment="Center" Foreground="#475569" FontSize="13"/>
                    <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding Month}" MinWidth="130"/>
                </StackPanel>
            </Grid>

            <!-- Drill-up -->
            <Button Content="↩ 集計に戻る" Command="{Binding DrillUpCommand}"
                    IsVisible="{Binding CanDrillUp}" HorizontalAlignment="Left"
                    Background="#E2E8F0" Foreground="#0F172A" Padding="14,7" CornerRadius="4"/>

            <!-- KPI cards -->
            <Grid ColumnDefinitions="*,*,*">
                <Border Classes="card" Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="総回答数" Foreground="#64748B" FontSize="13"/>
                        <TextBlock Text="{Binding TotalResponses}" Foreground="#0F172A" FontSize="30" FontWeight="Bold"/>
                        <TextBlock Text="件" Foreground="#94A3B8" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Classes="card" Grid.Column="1" Margin="8,0,8,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ネガティブ件数" Foreground="#64748B" FontSize="13"/>
                        <TextBlock Text="{Binding NegativeDisplay}" Foreground="#DC2626" FontSize="30" FontWeight="Bold"/>
                        <TextBlock Text="要対応 / 担当者へ通知対象" Foreground="#94A3B8" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Classes="card" Grid.Column="2" Margin="8,0,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="平均感情スコア" Foreground="#64748B" FontSize="13"/>
                        <TextBlock Text="{Binding AverageSentiment}" Foreground="#16A34A" FontSize="30" FontWeight="Bold"/>
                        <TextBlock Text="-1.0 (否定) 〜 +1.0 (肯定)" Foreground="#94A3B8" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts -->
            <Grid ColumnDefinitions="*,*">

                <!-- Topic bar chart (clickable to drill down) -->
                <Border Classes="card" Grid.Column="0" Margin="0,0,9,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding LevelTitle}" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="棒をクリックすると内訳にドリルダウンします" FontSize="11" Foreground="#94A3B8"
                                   IsVisible="{Binding ShowDrillHint}"/>
                        <TextBlock Text="トピック分析は LLM 連携後に表示されます。" FontSize="12" Foreground="#94A3B8"
                                   TextWrapping="Wrap" IsVisible="{Binding AnalysisPending}"/>
                        <ItemsControl ItemsSource="{Binding TopicBars}" x:CompileBindings="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="bar"
                                            Command="{Binding DataContext.DrillIntoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Label}">
                                        <Grid ColumnDefinitions="120,200,*" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="13"
                                                       Foreground="#334155" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="1" Height="20" HorizontalAlignment="Left" CornerRadius="4"
                                                    Width="{Binding BarWidth}"
                                                    Background="{Binding Accent, Converter={StaticResource HexBrush}}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="12"
                                                       Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Sentiment bar chart -->
                <Border Classes="card" Grid.Column="1" Margin="9,0,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="感情極性の分布" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="感情分析は LLM 連携後に表示されます。" FontSize="12" Foreground="#94A3B8"
                                   TextWrapping="Wrap" IsVisible="{Binding AnalysisPending}"/>
                        <ItemsControl ItemsSource="{Binding SentimentBars}" x:CompileBindings="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="90,200,*" VerticalAlignment="Center" Margin="0,6">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="13"
                                                   Foreground="#334155" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Height="20" HorizontalAlignment="Left" CornerRadius="4"
                                                Width="{Binding BarWidth}"
                                                Background="{Binding Accent, Converter={StaticResource HexBrush}}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="12"
                                                   Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Responses table -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="回答一覧（抜粋）" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <TextBlock Text="まだ回答がありません。サイドバーの「インポート (CSV)」から取り込めます。"
                               FontSize="13" Foreground="#94A3B8" TextWrapping="Wrap"
                               IsVisible="{Binding HasNoResponses}"/>
                    <DataGrid ItemsSource="{Binding Rows}" IsReadOnly="True" AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" Height="240">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="記入日" Binding="{Binding EntryDate}" Width="130"/>
                            <DataGridTextColumn Header="トピック" Binding="{Binding Topic}" Width="150"/>
                            <DataGridTextColumn Header="感情" Binding="{Binding Sentiment}" Width="90"/>
                            <DataGridTextColumn Header="抜粋（フリーテキスト）" Binding="{Binding Excerpt}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
