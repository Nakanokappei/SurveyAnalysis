<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="460">
        <TextBlock Text="プロジェクトを開始しましょう" FontSize="30" FontWeight="Bold" Foreground="#0F172A"
                   HorizontalAlignment="Center"/>
        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="#475569" FontSize="14"
                   Text="プロジェクトを作成すると、スキャン画像の読み込み・トピック割り当て・感情分析・月次レポートを管理できます。"/>

        <!-- 最近のプロジェクト：保存済みがあるときだけ表示。クリックで開く。 -->
        <StackPanel Spacing="6" IsVisible="{Binding HasRecentProjects}" Margin="0,4,0,0">
            <TextBlock Text="最近のプロジェクト" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
            <ScrollViewer MaxHeight="240" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding RecentProjects}" x:CompileBindings="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Margin="0,0,0,6" Padding="14,10"
                                    Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding FieldCountDisplay}" FontSize="12" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding UpdatedDisplay}" FontSize="12" Foreground="#94A3B8"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <Button Content="＋ プロジェクトを作る" Command="{Binding CreateProjectCommand}"
                HorizontalAlignment="Center" Padding="22,12" FontSize="15"
                Background="#005FB8" Foreground="White" CornerRadius="4"/>
        <Button Content="サンプルプロジェクトを開く" Command="{Binding OpenSampleCommand}"
                HorizontalAlignment="Center" Padding="18,9" FontSize="13"
                Background="Transparent" Foreground="#005FB8"/>
    </StackPanel>
</UserControl>
