<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.ImportView"
             x:DataType="vm:ImportViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0F000000"/>
        </Style>
        <Style Selector="TextBlock.hdr">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="16">

            <!-- ウィンドウのタイトルバーが「インポート (CSV)」を表示するので、本文では見出しを重複させない -->
            <TextBlock Text="デジタルに回収したアンケートのCSVを取り込み、既存データにマージします。"
                       FontSize="13" Foreground="#64748B"/>

            <!-- File select + merge -->
            <Border Classes="card">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="CSVファイル" Foreground="#64748B" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedFile}" Foreground="#0F172A" FontSize="14"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="ファイルを選択" Command="{Binding SelectFileCommand}"
                            VerticalAlignment="Center" Margin="0,0,10,0"
                            Background="#E2E8F0" Foreground="#0F172A" Padding="14,9" CornerRadius="4"/>
                    <Button Grid.Column="2" Content="マージ" Command="{Binding MergeCommand}"
                            VerticalAlignment="Center" Background="#005FB8" Foreground="White"
                            Padding="18,9" CornerRadius="4" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Foreground="#B45309" FontSize="13"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Preview: single record (単票) with row navigation + per-column mapping -->
            <Border Classes="card">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="取り込みプレビュー（単票）" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#0F172A" VerticalAlignment="Center"/>
                        <!-- 行ナビゲーション（先頭・戻る・現在/総数・次へ・最後） -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button Content="◀◀ 先頭" Command="{Binding FirstCommand}"
                                    Background="#E2E8F0" Foreground="#0F172A" Padding="10,6" CornerRadius="4"/>
                            <Button Content="◀ 戻る" Command="{Binding PreviousCommand}"
                                    Background="#E2E8F0" Foreground="#0F172A" Padding="10,6" CornerRadius="4"/>
                            <TextBlock Text="{Binding RowPosition}" VerticalAlignment="Center" MinWidth="56"
                                       TextAlignment="Center" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <Button Content="次へ ▶" Command="{Binding NextCommand}"
                                    Background="#E2E8F0" Foreground="#0F172A" Padding="10,6" CornerRadius="4"/>
                            <Button Content="最後 ▶▶" Command="{Binding LastCommand}"
                                    Background="#E2E8F0" Foreground="#0F172A" Padding="10,6" CornerRadius="4"/>
                        </StackPanel>
                    </Grid>

                    <!-- 見出し：CSVの列 / 取り込み先（項目） / 値 -->
                    <Grid ColumnDefinitions="150,200,*">
                        <TextBlock Grid.Column="0" Text="CSVの列" Classes="hdr"/>
                        <TextBlock Grid.Column="1" Text="取り込み先（項目）" Classes="hdr"/>
                        <TextBlock Grid.Column="2" Text="値" Classes="hdr" Margin="12,0,0,0"/>
                    </Grid>
                    <Border Height="1" Background="#E2E8F0"/>

                    <!-- 単票：列は固定（列名の横に対応づけドロップダウン）、値だけ行移動で更新 -->
                    <ItemsControl ItemsSource="{Binding Columns}" x:CompileBindings="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="150,200,*" Margin="0,5">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                               Foreground="#334155" FontWeight="SemiBold"/>
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,12,0"
                                              PlaceholderText="（未選択）" PlaceholderForeground="#DC2626"
                                              ItemsSource="{Binding DataContext.MappingOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding SelectedMapping}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentValue}" VerticalAlignment="Center"
                                               Foreground="#0F172A" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- マージは全列の取り込み先が決まるまで無効（未選択を残せない） -->
                    <TextBlock Text="すべての列の取り込み先を選ぶと「マージ」が有効になります（取り込まない列は「（取り込まない）」を選択）。"
                               FontSize="12" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
