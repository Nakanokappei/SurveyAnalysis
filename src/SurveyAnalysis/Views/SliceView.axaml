<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.SliceView"
             x:DataType="vm:SliceViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0F000000"/>
        </Style>
        <Style Selector="TextBlock.cell">
            <Setter Property="Width" Value="100"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="18">

            <!-- Header: slice title + description (left); 集計期間 (right) -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#64748B"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="集計期間" VerticalAlignment="Center" Foreground="#475569" FontSize="13"/>
                    <ComboBox ItemsSource="{Binding Periods}" SelectedItem="{Binding SelectedPeriod}"
                              MinWidth="100" x:CompileBindings="False">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding CountSummary}" FontSize="13" Foreground="#64748B"
                               IsVisible="{Binding HasData}"/>
                    <TextBlock Text="{Binding EmptyMessage}" FontSize="13" Foreground="#94A3B8"
                               TextWrapping="Wrap" IsVisible="{Binding !HasData}"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding HasData}">
                        <StackPanel Spacing="0">
                            <StackPanel Orientation="Horizontal" Margin="6,0,6,4">
                                <TextBlock Text="{Binding DimensionTitle}" Width="170" FontSize="12" Foreground="#94A3B8"/>
                                <ItemsControl ItemsSource="{Binding Columns}" x:CompileBindings="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="100">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#475569" TextAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding AggregationLabel}" FontSize="10"
                                                           Foreground="#94A3B8" TextAlignment="Right"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Rows}" x:CompileBindings="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,7">
                                            <TextBlock Text="{Binding Label}" Width="170" FontSize="13"
                                                       Foreground="#334155" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Classes="cell" Text="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- 全体 row: 平均は全体平均、その他は全体件数 -->
                            <Border BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Margin="6,2,0,0"
                                    Padding="0,6,0,0" IsVisible="{Binding HasTotal}">
                                <StackPanel Orientation="Horizontal" DataContext="{Binding TotalRow}" x:CompileBindings="False">
                                    <TextBlock Text="{Binding Label}" Width="170" FontSize="13"
                                               FontWeight="SemiBold" Foreground="#334155"/>
                                    <ItemsControl ItemsSource="{Binding Cells}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Classes="cell" FontWeight="SemiBold" Text="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
