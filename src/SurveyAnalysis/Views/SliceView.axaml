<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.SliceView"
             x:DataType="vm:SliceViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0F000000"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="18">

            <!-- Header: slice title + description, with the time-grain selector (time slice only) -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#64748B"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                            IsVisible="{Binding ShowGrainSelector}">
                    <TextBlock Text="粒度" VerticalAlignment="Center" Foreground="#475569" FontSize="13"/>
                    <ComboBox ItemsSource="{Binding Grains}" SelectedItem="{Binding SelectedGrain}"
                              MinWidth="120" x:CompileBindings="False">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding CountSummary}" FontSize="13" Foreground="#64748B"
                               IsVisible="{Binding HasData}"/>

                    <!-- Explanation when the slice has nothing to chart -->
                    <TextBlock Text="{Binding EmptyMessage}" FontSize="13" Foreground="#94A3B8"
                               TextWrapping="Wrap" IsVisible="{Binding !HasData}"/>

                    <!-- Grouped horizontal bars (dimension value → count) -->
                    <ItemsControl ItemsSource="{Binding Bars}" IsVisible="{Binding HasData}" x:CompileBindings="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="170,240,*" VerticalAlignment="Center" Margin="0,5">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="13"
                                               Foreground="#334155" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="1" Height="20" HorizontalAlignment="Left" CornerRadius="4"
                                            Width="{Binding BarWidth}" Background="#005FB8"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="12"
                                               Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
