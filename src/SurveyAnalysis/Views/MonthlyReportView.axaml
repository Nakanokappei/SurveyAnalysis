<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.MonthlyReportView"
             x:DataType="vm:MonthlyReportViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 4 0 #0F000000"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="18">

            <!-- Header + actions -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding CompanyName}" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="月次レポート" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock FontSize="13" Foreground="#64748B">
                        <Run Text="{Binding ProjectName}"/><Run Text="  ・  "/><Run Text="{Binding Month}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Content="📄 PDFを出力" Command="{Binding ExportPdfCommand}"
                            Background="#E2E8F0" Foreground="#0F172A" Padding="14,9" CornerRadius="4"/>
                    <Button Content="✉ 経営向けに送信" Command="{Binding SendEmailCommand}"
                            Background="#005FB8" Foreground="White" Padding="14,9" CornerRadius="4"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding StatusMessage}" Foreground="#B45309" FontSize="13"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- KPI cards -->
            <Grid ColumnDefinitions="*,*,*,*">
                <Border Classes="card" Grid.Column="0" Margin="0,0,6,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="総回答数" Foreground="#64748B" FontSize="13"/>
                        <TextBlock Text="{Binding TotalResponses}" Foreground="#0F172A" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Classes="card" Grid.Column="1" Margin="6,0,6,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ネガティブ件数" Foreground="#64748B" FontSize="13"/>
                        <TextBlock Text="{Binding NegativeCount}" Foreground="#DC2626" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Classes="card" Grid.Column="2" Margin="6,0,6,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="平均感情スコア" Foreground="#64748B" FontSize="13"/>
                        <TextBlock Text="{Binding AverageSentiment}" Foreground="#16A34A" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Classes="card" Grid.Column="3" Margin="6,0,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="回答率" Foreground="#64748B" FontSize="13"/>
                        <TextBlock Text="{Binding ResponseRate}" Foreground="#0F172A" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Topic distribution -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="トピック別 件数" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <ItemsControl ItemsSource="{Binding TopicBars}" x:CompileBindings="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="130,200,*" VerticalAlignment="Center" Margin="0,5">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="13"
                                               Foreground="#334155" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="20" HorizontalAlignment="Left" CornerRadius="4"
                                            Width="{Binding BarWidth}"
                                            Background="{Binding Accent, Converter={StaticResource HexBrush}}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="12"
                                               Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Highlights -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="経営向けハイライト" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <ItemsControl ItemsSource="{Binding Highlights}" x:CompileBindings="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
                                    <TextBlock Text="•" Foreground="#005FB8" FontSize="15"/>
                                    <TextBlock Text="{Binding}" Foreground="#334155" FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
