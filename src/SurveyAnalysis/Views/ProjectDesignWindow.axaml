<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SurveyAnalysis.ViewModels"
        xmlns:views="using:SurveyAnalysis.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="890" d:DesignHeight="550"
        x:Class="SurveyAnalysis.Views.ProjectDesignWindow"
        x:DataType="vm:ProjectDesignViewModel"
        Width="890" Height="550"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="プロジェクト作成">

    <!-- ダイアログ寸法は黄金比（890:550 ≈ 1.618:1）。設定・インポートと統一。 -->

    <Design.DataContext>
        <vm:ProjectDesignViewModel/>
    </Design.DataContext>

    <views:ProjectDesignView/>
</Window>
