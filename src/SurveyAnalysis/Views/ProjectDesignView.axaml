<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SurveyAnalysis.ViewModels"
             xmlns:behaviors="using:SurveyAnalysis.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="720"
             x:Class="SurveyAnalysis.Views.ProjectDesignView"
             x:DataType="vm:ProjectDesignViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #0D000000"/>
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Background="#F8FAFC">

        <!-- Action bar pinned to the bottom of the dialog (always visible, not scrolled). -->
        <Border DockPanel.Dock="Bottom" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="28,12">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="キャンセル" Command="{Binding CancelCommand}"
                        Background="Transparent" Foreground="#475569" Padding="16,9"/>
                <Button Content="このデータ形式で作成" Command="{Binding CreateProjectCommand}"
                        Background="#005FB8" Foreground="White" Padding="18,10" CornerRadius="4" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <ScrollViewer>
            <StackPanel Margin="28" Spacing="16">

                <TextBlock Text="アンケート用紙の各項目に、データ型と分析方法を割り当てます。" FontSize="13" Foreground="#64748B"/>

            <!-- Project name -->
            <Border Classes="card">
                <StackPanel Spacing="4">
                    <TextBlock Classes="caption" Text="プロジェクト名"/>
                    <TextBox Text="{Binding ProjectName}" Watermark="例：○○ケーブル 工事アンケート"
                             behaviors:RequiredField.IsRequired="True"/>
                </StackPanel>
            </Border>

            <!-- Section header -->
            <TextBlock Text="データ項目" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>

            <!-- Field rows (vertical list); each item is a rounded card -->
            <ItemsControl x:Name="FieldsItems" ItemsSource="{Binding Fields}" x:CompileBindings="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="card" Margin="0,0,0,12">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <Grid ColumnDefinitions="*,180,200">

                                    <!-- 項目名 -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Classes="caption" Text="項目名"/>
                                        <TextBox Text="{Binding Name}" Watermark="項目名"
                                                 behaviors:RequiredField.IsRequired="True"/>
                                    </StackPanel>

                                    <!-- データ型 -->
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Classes="caption" Text="データ型"/>
                                        <ComboBox ItemsSource="{Binding FieldTypeOptions}" SelectedItem="{Binding FieldType}"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Border IsVisible="{Binding IsPersonalInformation}" Background="#FEF3C7"
                                                CornerRadius="6" Padding="8,3" Margin="0,6,0,0" HorizontalAlignment="Left">
                                            <TextBlock Text="🔒 暗号化・非表示" FontSize="11" Foreground="#92400E"/>
                                        </Border>
                                        <!-- 月次集計の基準日（日付型のときのみ。これが無いと月次集計できない） -->
                                        <CheckBox IsVisible="{Binding IsDate}" IsChecked="{Binding UseForAggregation}"
                                                  Content="月次集計に使う" FontSize="12" Margin="0,4,0,0"/>
                                        <!-- 読み込み日をデフォルトに（集計に使うときは値必須のため固定オン） -->
                                        <CheckBox IsVisible="{Binding IsDate}" IsChecked="{Binding UseLoadDateAsDefault}"
                                                  IsEnabled="{Binding UseLoadDateAsDefaultEnabled}"
                                                  Content="読み込み日をデフォルトにする" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- 分析方法 -->
                                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                        <TextBlock Classes="caption" Text="分析方法"/>
                                        <ComboBox ItemsSource="{Binding AnalysisOptions}" SelectedItem="{Binding Analysis}"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    </Grid>

                                    <!-- 感情極性分析のときのアラート設定（発報チェック＋閾値） -->
                                    <StackPanel Spacing="8" IsVisible="{Binding IsSentimentSelected}">
                                        <CheckBox IsChecked="{Binding EnableAlert}" Content="アラートを発報する" FontSize="13"/>
                                        <!-- 閾値（アラートを発報するときだけ。範囲 -0.9〜+0.5） -->
                                        <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding ShowThreshold}">
                                            <TextBlock Text="アラート閾値" Classes="caption" VerticalAlignment="Center" Margin="0"/>
                                            <Slider Minimum="-0.9" Maximum="0.5" Value="{Binding AlertThreshold}" Width="260"
                                                    TickFrequency="0.1" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding AlertThreshold, StringFormat={}{0:0.0}}"
                                                       FontWeight="SemiBold" Foreground="#DC2626" VerticalAlignment="Center" Width="36"/>
                                            <TextBlock Text="を下回ると担当者へ通知" Classes="caption" VerticalAlignment="Center" Margin="0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 削除（項目カードの上下中央・角丸の外枠でボタンと分かるように） -->
                                <Button Grid.Column="1" Content="削除" VerticalAlignment="Center" Margin="12,0,0,0"
                                        Command="{Binding DataContext.RemoveFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#DC2626"
                                        BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="4" Padding="14,6"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add a new item as the last row; focus moves to the new field (see code-behind) -->
            <Button Content="＋ 項目を追加" Click="OnAddFieldClick"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Background="Transparent" Foreground="#005FB8"
                    BorderBrush="#CBD5E1" BorderThickness="1" Padding="0,12" CornerRadius="8"/>

            <!-- Test panel: specify one image ad-hoc (a new project has no loaded responses yet) -->
            <Border Classes="card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="12">
                    <TextBlock Text="データ形式をテスト" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <TextBlock Classes="caption" Margin="0"
                               Text="アンケート用紙の画像を1枚指定して、上のデータ項目で何が抽出されるかを確認できます。"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button Content="画像を選択…" Command="{Binding PickTestImageCommand}"
                                Background="#E2E8F0" Foreground="#0F172A" Padding="14,8" CornerRadius="4"/>
                        <TextBlock Text="{Binding TestImagePath}" VerticalAlignment="Center" Foreground="#334155"
                                   IsVisible="{Binding HasTestImage}"/>
                        <TextBlock Text="（画像が未選択）" VerticalAlignment="Center" Foreground="#94A3B8"
                                   IsVisible="{Binding !HasTestImage}"/>
                        <Button Content="テスト実行" Command="{Binding RunTestCommand}" IsEnabled="{Binding HasTestImage}"
                                Background="#005FB8" Foreground="White" Padding="14,8" CornerRadius="4"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding TestResults}" IsVisible="{Binding HasTestResult}"
                              IsReadOnly="True" AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" Height="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="項目名" Binding="{Binding FieldName}" Width="160"/>
                            <DataGridTextColumn Header="データ型" Binding="{Binding FieldTypeLabel}" Width="120"/>
                            <DataGridTextColumn Header="分析方法" Binding="{Binding AnalysisLabel}" Width="140"/>
                            <DataGridTextColumn Header="分析結果" Binding="{Binding AnalysisResult}" Width="140"/>
                            <DataGridTextColumn Header="抽出値（プレビュー）" Binding="{Binding ExtractedValue}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </StackPanel>

                    <!-- 指定した画像のサムネイル（テストエリアの右上） -->
                    <Border Grid.Column="1" VerticalAlignment="Top" IsVisible="{Binding HasTestImage}"
                            Width="120" Margin="16,0,0,0" BorderBrush="#CBD5E1" BorderThickness="1"
                            CornerRadius="4" ClipToBounds="True">
                        <Image Source="avares://SurveyAnalysis/Assets/Sample/sample_survey.jpg" Stretch="Uniform"/>
                    </Border>
                </Grid>
            </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
