<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SurveyAnalysis.ViewModels"
        xmlns:views="using:SurveyAnalysis.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="890" d:DesignHeight="550"
        x:Class="SurveyAnalysis.Views.ImportWindow"
        x:DataType="vm:ImportViewModel"
        Width="890" Height="550"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="インポート (CSV)">

    <!-- ダイアログ寸法は黄金比（890:550 ≈ 1.618:1）。プロジェクト作成・設定と統一。 -->
    <views:ImportView/>
</Window>
